DATABASE_URL=sqlite:///./kkrit.db
SECRET_KEY=change-this-secret-key-in-production
DEBUG=True

# ─── Безопасность и CORS ───
# CORS origins (через запятую). Для production укажи реальные домены:
# CORS_ORIGINS=http://localhost:5173,https://your-domain.com
#
# Или используй JSON массив для сложных случаев:
# CORS_ORIGINS_JSON=["http://localhost:5173", "https://your-domain.com"]
#
# Rate limiting - защита от DDoS (по умолчанию 100 запросов в минуту)
# RATE_LIMIT_ENABLED=True
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_PERIOD=60

# ─── Надёжность базы данных ───
# SQLite WAL mode - включен по умолчанию для лучшей конкурентности
# Помогает избежать "database is locked" ошибок
# SQLITE_WAL_MODE=True

# ─── Retry настройки для внешних API ───
# Количество попыток при ошибках сети (Яндекс.Диск, парсинг новостей)
# EXTERNAL_API_MAX_RETRIES=3
# Задержка между попытками в секундах (будет увеличиваться экспоненциально)
# EXTERNAL_API_RETRY_DELAY=1.0
# Таймаут HTTP запросов в секундах
# EXTERNAL_API_TIMEOUT=15

# ─── Синхронизация расписания с Яндекс.Диска ───
# Если задано — бэкенд каждые N часов скачивает PDF/XLSX из публичной папки
# и импортирует в БД. Если не задано — фоновая задача не запускается.
# YANDEX_DISK_PUBLIC_URL=https://disk.yandex.ru/d/your-public-folder
# YANDEX_DISK_SYNC_INTERVAL_HOURS=3
# Обходить вложенные подпапки (архивы по месяцам типа «апрель», «март»).
# По умолчанию True. Поставь False, если расписание лежит только в корне.
# YANDEX_DISK_RECURSIVE=True
