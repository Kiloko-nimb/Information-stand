# ─── Frontend (Vite) env ───
# Все переменные должны начинаться с VITE_, иначе Vite их не «прокинет» в сборку.

# ─── Киоск-режим ───
# Через сколько секунд бездействия возвращать пользователя на главную.
# Сбрасывается на любой клик/тап/движение мыши/нажатие клавиши.
# По умолчанию 180 секунд (3 минуты).
# VITE_KIOSK_TIMEOUT_SEC=180

# За сколько секунд до возврата показывать оверлей с обратным отсчётом
# («Возврат на главную, тапни чтобы остаться»). По умолчанию 10.
# Можно поставить 0, чтобы вернуться без предупреждения.
# VITE_KIOSK_WARNING_SEC=10
